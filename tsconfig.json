{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@bpmn-react/react/styles.css": ["bpmn/packages/react/styles.css"],
      "@bpmn-react/*": ["bpmn/packages/*/dist/esm/index.d.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}

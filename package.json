{
  "name": "bpmnplay",
  "private": true,
  "version": "0.1.0",
  "description": "Playground/ambiente de teste para a biblioteca bpmn-react (submódulo bpmn/).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "playwright test",
    "update-lib": "git submodule update --remote bpmn && pnpm --dir bpmn install && pnpm --dir bpmn -r run build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
